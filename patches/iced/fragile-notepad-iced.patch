+        pixels.draw_pixmap(
+            x,
+            y,
+            pixmap,
+            paint,
+            tiny_skia::Transform::identity(),
+            clip_mask,
+        );
+        return;
+    };
+
+    let Some(source) = clipped_source_rect(x, y, pixmap.width(), pixmap.height(), clip_bounds)
+    else {
+        return;
+    };
+
+    if source.x() == 0
+        && source.y() == 0
+        && source.width() == pixmap.width()
+        && source.height() == pixmap.height()
+    {
+        pixels.draw_pixmap(
+            x,
+            y,
+            pixmap,
+            paint,
+            tiny_skia::Transform::identity(),
+            None,
+        );
+        return;
+    }
+
+    let Some(cropped) = pixmap.clone_rect(source) else {
+        return;
+    };
+
+    pixels.draw_pixmap(
+        x + source.x(),
+        y + source.y(),
+        cropped.as_ref(),
+        paint,
+        tiny_skia::Transform::identity(),
+        None,
+    );
