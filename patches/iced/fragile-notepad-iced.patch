+fn draw_pixmap_clipped(
+    pixels: &mut tiny_skia::PixmapMut<'_>,
+    x: i32,
+    y: i32,
+    pixmap: tiny_skia::PixmapRef<'_>,
+    paint: &tiny_skia::PixmapPaint,
+    clip_mask: Option<&tiny_skia::Mask>,
+    clip_bounds: Option<Rectangle>,
