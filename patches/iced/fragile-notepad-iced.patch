+#[cfg(target_os = "linux")]
+fn linux_startup_activation_token() -> Option<String> {
+    const X11_VAR: &str = "DESKTOP_STARTUP_ID";
+    const WAYLAND_VAR: &str = "XDG_ACTIVATION_TOKEN";
+
+    let token = std::env::var(WAYLAND_VAR)
+        .ok()
+        .filter(|value| !value.is_empty())
+        .or_else(|| {
+            std::env::var(X11_VAR)
+                .ok()
+                .filter(|value| !value.is_empty())
+        });
+
+    if token.is_some() {
+        winit::platform::startup_notify::reset_activation_token_env();
+    }
+
+    token
+}
