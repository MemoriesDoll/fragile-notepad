+//! OEM code page encoding extensions.
+
+use alloc::string::String;
+use alloc::vec::Vec;
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub enum OemCodePage {
+    Cp437,
+    Cp720,
+    Cp737,
+    Cp775,
+    Cp850,
+    Cp852,
+    Cp855,
+    Cp857,
+    Cp858,
+    Cp860,
+    Cp861,
+    Cp862,
+    Cp863,
+    Cp865,
+    Cp866,
+    Cp869,
+}
+
+impl OemCodePage {
+    pub const fn label(self) -> &'static str {
+        match self {
+            Self::Cp437 => "OEM-US",
+            Self::Cp720 => "OEM 720",
+            Self::Cp737 => "OEM 737",
+            Self::Cp775 => "OEM 775",
+            Self::Cp850 => "OEM 850",
+            Self::Cp852 => "OEM 852",
+            Self::Cp855 => "OEM 855",
+            Self::Cp857 => "OEM 857",
+            Self::Cp858 => "OEM 858",
+            Self::Cp860 => "OEM 860 : Portuguese",
+            Self::Cp861 => "OEM 861 : Icelandic",
+            Self::Cp862 => "OEM 862",
+            Self::Cp863 => "OEM 863 : French",
+            Self::Cp865 => "OEM 865 : Nordic",
+            Self::Cp866 => "OEM 866",
+            Self::Cp869 => "OEM 869",
+        }
+    }
+
+    const fn high_table(self) -> &'static [char; 128] {
+        match self {
+            Self::Cp437 => &OEM_437_HIGH,
+            Self::Cp720 => &OEM_720_HIGH,
+            Self::Cp737 => &OEM_737_HIGH,
+            Self::Cp775 => &OEM_775_HIGH,
+            Self::Cp850 => &OEM_850_HIGH,
+            Self::Cp852 => &OEM_852_HIGH,
+            Self::Cp855 => &OEM_855_HIGH,
+            Self::Cp857 => &OEM_857_HIGH,
+            Self::Cp858 => &OEM_858_HIGH,
+            Self::Cp860 => &OEM_860_HIGH,
+            Self::Cp861 => &OEM_861_HIGH,
+            Self::Cp862 => &OEM_862_HIGH,
+            Self::Cp863 => &OEM_863_HIGH,
+            Self::Cp865 => &OEM_865_HIGH,
+            Self::Cp866 => &OEM_866_HIGH,
+            Self::Cp869 => &OEM_869_HIGH,
+        }
+    }
+}
+
+#[derive(Debug, Clone, Copy, PartialEq, Eq)]
+pub struct OemEncodingError;
+
+pub fn decode_oem(bytes: &[u8], code_page: OemCodePage) -> String {
+    let table = code_page.high_table();
+    let mut decoded = String::with_capacity(bytes.len());
+
+    for &byte in bytes {
+        if byte < 0x80 {
+            decoded.push(char::from(byte));
+        } else {
+            decoded.push(table[usize::from(byte - 0x80)]);
+        }
+    }
+
+    decoded
+}
+
+pub fn encode_oem(text: &str, code_page: OemCodePage) -> Result<Vec<u8>, OemEncodingError> {
+    let table = code_page.high_table();
+    let mut encoded = Vec::with_capacity(text.len());
+
+    for ch in text.chars() {
+        let code = ch as u32;
+        if code < 0x80 {
+            encoded.push(code as u8);
+        } else if let Some(index) = table.iter().position(|candidate| *candidate == ch) {
+            encoded.push(0x80 + index as u8);
+        } else {
+            return Err(OemEncodingError);
+        }
+    }
+
+    Ok(encoded)
+}
